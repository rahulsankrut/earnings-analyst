# ── Google Cloud Project ────────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=1

# ── Agent Engine Deployment ─────────────────────────────────────────────────
# Staging buckets used by Agent Engine during deployment (must exist, one per agent)
GOOGLE_CLOUD_STORAGE_BUCKET=your-phoenix-staging-bucket
IE_STAGING_BUCKET=your-ie-staging-bucket
AGENT_SERVICE_ACCOUNT=your-sa@your-project.iam.gserviceaccount.com

# ── Vertex AI Search Data Stores ────────────────────────────────────────────
EARNINGS_DATA_STORE_ID=your-earnings-datastore-id
COMPETITOR_DATA_STORE_ID=your-competitor-datastore-id
DATA_STORE_LOCATION=global

# ── GCS Buckets ─────────────────────────────────────────────────────────────
# Bucket where extracted intelligence reports are stored and read by Phoenix
INTELLIGENCE_BUCKET=your-intelligence-bucket
# Bucket holding source PDF documents for Vertex AI Search ingestion
DOCUMENT_BUCKET=your-document-bucket
# Filename substring to skip when uploading documents (leave blank to upload all)
SKIP_PATTERN=

# ── Models ───────────────────────────────────────────────────────────────────
PHOENIX_MODEL=gemini-2.5-pro
PHOENIX_FLASH_MODEL=gemini-2.5-flash

# ── SDK / Auth ───────────────────────────────────────────────────────────────
CLOUDSDK_CONTEXT_AWARE_USE_CLIENT_CERTIFICATE=false
